# Logs (runtime output — directory tracked, contents ignored)
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Environment / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Data artifacts (snapshots/large data live outside VCS unless explicitly tracked)
*.tmp

# Large market data — Binance Kline archives and any machine-specific local data.
# Never commit full historical market data; it lives only on the machine that
# ran the ingestion pipeline.
local_data/

# Claude Code internal state
.claude/
